{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Rental Search API",
    "description": "This API provides access to publicly available data on the Australian rental market in 2026. The API endpoints and their usage are described in detail below."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Enter JWT Bearer token **_only_**"
      }
    }
  },
  "paths": {
    "/rentals/states": {
      "get": {
        "tags": ["Rentals"],
        "description": "Returns a list of Australian states and territories, ordered alphabetically.",
        "responses": {
          "200": {
            "description": "An array of state initialisms.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "examples": [["ACT","NSW","NT","Qld","SA","Tas","Vic","WA"]]
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "boolean",
                      "examples": [true]
                    },
                    "message": {
                      "type": "string",
                      "examples": ["Invalid query parameters: yourParamHere"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rentals/property-types": {
      "get": {
        "tags": ["Rentals"],
        "description": "Returns a list of rental property types, ordered alphabetically.",
        "responses": {
          "200": {
            "description": "An array of property types.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "examples": [["acreage/semi-rural","apartment","duplex/semi-detached","flat","house","other","studio","terrace","townhouse","unit","villa"]]
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "boolean",
                      "examples": [true]
                    },
                    "message": {
                      "type": "string",
                      "examples": ["Invalid query parameters: yourParamHere"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rentals/search": {
      "get": {
        "tags": ["Rentals"],
        "description": "Returns a list of rental properties, filtered and sorted as specified. If no sort order is specified, properties will be returned sorted by id in ascending order.",
        "parameters": [
          {
            "name": "suburb",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "postcode",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "maximum": 9999 }
          },
          {
            "name": "minimumRent",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "maximumRent",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "minimumBathrooms",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "maximumBathrooms",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "minimumBedrooms",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "maximumBedrooms",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "minimumParking",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "maximumParking",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "propertyTypes",
            "in": "query",
            "required": false,
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["acreage/semi-rural","apartment","duplex/semi-detached","flat","house","other","studio","terrace","townhouse","unit","villa"]
              }
            }
          },
          {
            "name": "minimumRating",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "maximumRating",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["rent", "bathrooms", "bedrooms", "parkingSpaces", "suburb", "latitude", "longitude", "postcode", "averageRating", "numRatings"]
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of rental properties.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "examples": [1] },
                          "title": { "type": "string", "examples": ["Auburn Townhouse For Lease"] },
                          "rent": { "type": "integer", "examples": [1200] },
                          "propertyType": { "type": "string", "examples": ["townhouse"] },
                          "latitude": { "type": "number", "examples": [-33.84077015] },
                          "longitude": { "type": "number", "examples": [151.00802461] },
                          "postcode": { "type": "integer", "examples": [2144] },
                          "state": { "type": "string", "examples": ["NSW"] },
                          "suburb": { "type": "string", "examples": ["Auburn"] },
                          "bathrooms": { "type": "integer", "examples": [2] },
                          "bedrooms": { "type": "integer", "examples": [4] },
                          "parkingSpaces": { "type": "integer", "examples": [2] },
                          "averageRating": { "type": ["number", "null"], "examples": [null] },
                          "numRatings": { "type": "integer", "examples": [0] }
                        }
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "total": { "type": "integer", "examples": [6767] },
                        "lastPage": { "type": "integer", "examples": [677] },
                        "prevPage": { "type": ["integer", "null"], "examples": [null] },
                        "nextPage": { "type": ["integer", "null"], "examples": [2] },
                        "perPage": { "type": "integer", "examples": [10] },
                        "currentPage": { "type": "integer", "examples": [1] },
                        "from": { "type": "integer", "examples": [0] },
                        "to": { "type": "integer", "examples": [10] }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid query parameters: yourParamHere"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid postcode parameter. Must be an integer in the range of 0000-9999."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid minimumRent parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid maximumRent parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid minimumBathrooms parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid maximumBathrooms parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid minimumBedrooms parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid maximumBedrooms parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid minimumParking parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid maximumParking parameter. Must be a non-negative integer."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid sortOrder parameter. Must be 'asc' or 'desc'."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid sortOrder parameter. sortBy must be specified."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid sortBy parameter. Must refer to a valid sortable property."] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid page parameter. Must be an integer greater than or equal to 1."] }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/rentals/{id}": {
      "get": {
        "tags": ["Rentals"],
        "description": "Returns an object containing data for the specified rental property.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Rental property data including ratings.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "title": { "type": "string" },
                    "rent": { "type": "integer" },
                    "propertyType": { "type": "string" },
                    "latitude": { "type": "number" },
                    "longitude": { "type": "number" },
                    "postcode": { "type": "integer" },
                    "state": { "type": "string" },
                    "suburb": { "type": "string" },
                    "bathrooms": { "type": "integer" },
                    "bedrooms": { "type": "integer" },
                    "parkingSpaces": { "type": "integer" },
                    "averageRating": { "type": ["number", "null"], "examples": [null] },
                    "numRatings": { "type": "integer", "examples": [0] },
                    "reviews": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "user": { "type": "string" },
                          "rating": { "type": "integer" },
                          "comment": { "type": "string" },
                          "dateTime": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["Invalid query parameters: yourParamHere"] }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Rental not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["No rental found with id 99999"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ratings/debugEraseRatings": {
      "post": {
        "tags": ["Ratings"],
        "description": "Debug route - erases all ratings from the database.",
        "responses": {
          "200": {
            "description": "All ratings erased.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "examples": ["All ratings erased"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ratings/rentals/{id}": {
      "get": {
        "tags": ["Ratings"],
        "description": "Returns the rating made by this user for the rental with the specified id. Requires authorisation.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Rating found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "integer", "examples": [4] },
                    "dateTime": { "type": "string", "examples": ["2026-03-14T23:47:45.371Z"] }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Authorization header ('Bearer token') not found"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["JWT token has expired"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid JWT token"] }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "No rating found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["No rating exists with this rental ID."] }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Ratings"],
        "description": "Post a rating for the rental property with the specified id. If already rated by this user, the existing rating will be overwritten. Requires authorisation.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "enum": [1, 2, 3, 4, 5] },
                  "comment": { "type": "string", "minLength": 1, "maxLength": 2000 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Rating successfully posted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "integer", "examples": [4] },
                    "comment": { "type": "string", "examples": ["Great place!"] },
                    "dateTime": { "type": "string", "examples": ["2026-03-14T23:47:45.371Z"] }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid comment.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["Invalid comment parameter. Comment must be a string 1-2000 characters long."] }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Authorization header ('Bearer token') not found"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["JWT token has expired"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Invalid JWT token"] }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Rental not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["No rental exists with this ID."] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/register": {
      "post": {
        "tags": ["Authentication"],
        "description": "Creates a new user account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "examples": ["mike@gmail.com"] },
                  "password": { "type": "string", "examples": ["password"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["User created"] }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing email or password.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["Request body incomplete - email and password needed"] }
                  }
                }
              }
            }
          },
          "500": {
            "description": "User already exists or server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "examples": [false] },
                    "message": { "type": "string", "examples": ["User already exists"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["Authentication"],
        "description": "Log in to an existing user account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "examples": ["mike@gmail.com"] },
                  "password": { "type": "string", "examples": ["password"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "examples": ["ajsonwebtoken"] },
                    "tokenType": { "type": "string", "examples": ["Bearer"] },
                    "expiresIn": { "type": "number", "examples": [86400] }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing email or password.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["Request body incomplete - email and password needed"] }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["User does not exist"] }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "examples": [true] },
                        "message": { "type": "string", "examples": ["Passwords do not match"] }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/user/debugLogin": {
      "post": {
        "tags": ["Authentication"],
        "description": "Log in with a 1-second expiry token for testing purposes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "examples": ["mike@gmail.com"] },
                  "password": { "type": "string", "examples": ["password"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful with short expiry token.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "examples": ["ajsonwebtoken"] },
                    "tokenType": { "type": "string", "examples": ["Bearer"] },
                    "expiresIn": { "type": "number", "examples": [1] }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing email or password.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "boolean", "examples": [true] },
                    "message": { "type": "string", "examples": ["Request body incomplete - email and password needed"] }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
